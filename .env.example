# Copy to `.env` and adjust. Every variable maps 1:1 to a field on
# app/config.py::Settings (case-insensitive). Anything unset uses the
# default declared there.

ENVIRONMENT=development
LOG_LEVEL=INFO

# LLM config. LLM_MODEL is the strong/escalation tier.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=

# Extraction self-correction agent (live LLM path only; never runs on the
# injected-content eval). Set EXTRACTION_AGENT_ENABLED=false to revert to the
# original single-shot extraction.
EXTRACTION_AGENT_ENABLED=true
EXTRACTION_CONFIDENCE_THRESHOLD=0.67
EXTRACTION_MAX_ATTEMPTS=3
LLM_MODEL_FAST=claude-haiku-4-5-20251001

# Override only if your policy file lives somewhere non-default.
# POLICY_FILE_PATH=policy_terms.json
